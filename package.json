{
  "name": "bibox-downloader",
  "version": "1.0.0",
  "description": "Portable BiBox 2.0 Offline Downloader — Download books and learning resources",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win portable",
    "dist:linux": "npm run build && electron-builder --linux AppImage",
    "dist:mac": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "p-queue": "^6.6.2",
    "pdf-lib": "^1.17.1",
    "undici": "^6.21.0",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "zustand": "^5.0.0"
  }
}
